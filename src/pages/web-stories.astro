---
import BaseLayout from '../layouts/BaseLayout.astro';

const stories = [
  {
    title: 'From IT Officer to Cloud Architect — My 10-Year Journey',
    slug: 'from-it-officer-to-cloud-architect',
    desc: 'How 11 years of hands-on tech work across healthcare, NOC operations, and enterprise deployments led to Azure Solutions Architect Expert.',
  },
  {
    title: 'Building SASSI: A Logistics Platform Built in the Caribbean',
    slug: 'building-sassi-logistics-platform',
    desc: 'WhatsApp messages, spreadsheets, and 200+ clients later — how we replaced manual operations with a full-stack Azure platform.',
  },
  {
    title: 'Azure Front Door: How We Protected a Healthcare App from Bot Attacks',
    slug: 'azure-front-door-healthcare-app',
    desc: 'CPU at 95%, real users impacted. The decision to add Azure Front Door and what happened after.',
  },
];
---

<BaseLayout
  title="Web Stories — Antonio Cumberbatch"
  description="Short-form visual stories about cloud architecture, building products in the Caribbean, and consulting life."
>

  <section style="padding:4rem 1.5rem 3rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <p class="reveal" style="font-size:0.8125rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);margin-bottom:0.5rem;">Web Stories</p>
      <h1 class="reveal" style="font-family:var(--font-display);font-size:clamp(2rem,5vw,3rem);font-weight:800;margin-bottom:1rem;">Visual Stories</h1>
      <p class="reveal" style="font-size:1.0625rem;color:var(--color-text-muted);max-width:560px;">Swipeable visual stories about cloud, tech, and building in the Caribbean. Created in Google Web Stories.</p>
    </div>
  </section>

  <section style="padding:0 1.5rem 2rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <div class="reveal" style="background:rgba(255,107,43,0.06);border:1px solid rgba(255,107,43,0.15);border-radius:10px;padding:1.25rem 1.5rem;margin-bottom:3rem;">
        <p style="font-size:0.9rem;color:var(--color-text-muted);margin:0;">
          Web Stories are built using the <a href="https://googlechrome.dev/tools/web-stories" target="_blank" rel="noopener noreferrer" style="color:var(--color-accent);">Google Web Stories editor</a> and hosted as standalone HTML files. Click a story below to open it.
        </p>
      </div>
    </div>
  </section>

  <section style="padding:0 1.5rem 5rem;">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.5rem;">
      {stories.map(story => (
        <a href={`/stories/${story.slug}.html`} class="card-lift reveal" style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;overflow:hidden;text-decoration:none;display:block;">
          <div style="aspect-ratio:9/16;background:var(--color-surface-2);display:flex;align-items:center;justify-content:center;position:relative;">
            <span style="font-size:2rem;">&#x1F4F1;</span>
            <span style="position:absolute;bottom:0.75rem;right:0.75rem;background:var(--color-accent);color:#fff;font-size:0.6875rem;font-weight:700;padding:0.25rem 0.5rem;border-radius:4px;">Story</span>
            <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.6) 0%,transparent 50%);"></div>
          </div>
          <div style="padding:1.25rem;">
            <h2 style="font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--color-text);margin:0 0 0.5rem;line-height:1.3;">{story.title}</h2>
            <p style="font-size:0.875rem;color:var(--color-text-muted);line-height:1.5;margin:0;">{story.desc}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="reveal" style="max-width:1200px;margin:2.5rem auto 0;background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:2rem;text-align:center;">
      <p style="color:var(--color-text-muted);margin:0 0 0.5rem;">Story files are added manually to <code style="font-family:var(--font-mono);font-size:0.875rem;background:var(--color-surface-2);padding:0.125rem 0.375rem;border-radius:3px;">public/stories/</code></p>
      <p style="font-size:0.875rem;color:var(--color-text-muted);margin:0;">More stories coming soon.</p>
    </div>
  </section>

</BaseLayout>
