---
import BaseLayout from '../layouts/BaseLayout.astro';

const resources = [
  {
    id: 'copilot-checklist',
    title: 'The AI & Copilot Staff Readiness Checklist',
    desc: 'Is your team actually ready for Microsoft Copilot? A practical checklist built from training 2,574+ professionals on Copilot adoption. Covers data governance, licensing, change management, and the adoption steps most rollouts skip.',
    cta: 'Get the Checklist',
    pdf: '/resources/ai-copilot-staff-readiness-checklist.pdf',
    webhook: 'https://automate.antoniocumberbatch.com/webhook/PLACEHOLDER-lead-magnet',
  },
  {
    id: 'cloud-readiness',
    title: 'The Caribbean Cloud Readiness Checklist',
    desc: 'A 20-point self-assessment for any Caribbean business considering a move to Azure. Covers infrastructure, security posture, cost, and migration sequencing.',
    cta: 'Get the Checklist',
    pdf: '/resources/caribbean-cloud-readiness-checklist.pdf',
    webhook: 'https://automate.antoniocumberbatch.com/webhook/PLACEHOLDER-lead-magnet',
  },
];
---

<BaseLayout
  title="Free Resources — Antonio Cumberbatch"
  description="Free checklists and tools built from real cloud and AI engagements. Copilot readiness, Azure migration, and Caribbean cloud strategy."
>

  <section style="padding:4rem 1.5rem 3rem;">
    <div style="max-width:900px;margin:0 auto;">
      <p class="reveal" style="font-size:0.8125rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);margin-bottom:0.5rem;">Free Resources</p>
      <h1 class="reveal" style="font-family:var(--font-display);font-size:clamp(2rem,5vw,3rem);font-weight:800;margin-bottom:1rem;">Free Tools &amp; Checklists</h1>
      <p class="reveal" style="font-size:1.0625rem;color:var(--color-text-muted);max-width:540px;">Practical checklists from real cloud and AI engagements. No fluff, just the things I actually check.</p>
    </div>
  </section>

  <section style="padding:0 1.5rem 6rem;">
    <div style="max-width:900px;margin:0 auto;display:flex;flex-direction:column;gap:2rem;">
      {resources.map(r => (
        <div class="reveal" style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:16px;overflow:hidden;">
          <div style="padding:2.5rem;border-bottom:1px solid var(--color-border);">
            <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:800;margin:0 0 0.875rem;">{r.title}</h2>
            <p style="font-size:1rem;color:var(--color-text-muted);line-height:1.7;max-width:640px;margin:0;">{r.desc}</p>
          </div>
          <div style="padding:2rem 2.5rem;">
            <form
              class="lead-form"
              data-pdf={r.pdf}
              data-webhook={r.webhook}
              style="display:flex;flex-wrap:wrap;gap:0.875rem;align-items:flex-end;"
            >
              <div style="flex:1;min-width:220px;">
                <label style="display:block;font-size:0.8125rem;font-weight:600;color:var(--color-text-muted);margin-bottom:0.375rem;">Your email</label>
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="you@company.com"
                  style="width:100%;background:var(--color-surface-2);border:1px solid var(--color-border);border-radius:8px;padding:0.6875rem 1rem;color:var(--color-text);font-size:0.9375rem;outline:none;box-sizing:border-box;"
                />
              </div>
              <button
                type="submit"
                style="background:var(--color-accent);color:#fff;padding:0.6875rem 1.5rem;border-radius:8px;font-weight:600;font-size:0.9375rem;border:none;cursor:pointer;white-space:nowrap;transition:background 0.2s;"
                onmouseover="this.style.background='var(--color-accent-hover)'"
                onmouseout="this.style.background='var(--color-accent)'"
              >
                {r.cta}
              </button>
            </form>
            <div class="lead-success" style="display:none;margin-top:1.25rem;padding:1.25rem;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:8px;">
              <p style="font-weight:600;color:#4ade80;margin:0 0 0.5rem;">You're all set.</p>
              <p style="font-size:0.9375rem;color:var(--color-text-muted);margin:0 0 0.875rem;">Check your inbox. If you don't see it within a few minutes, check your spam folder.</p>
              <a class="lead-download" href="#" style="font-size:0.875rem;font-weight:600;color:var(--color-accent);text-decoration:none;">Download directly &rarr;</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll('.lead-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const email = (f.elements.namedItem('email') as HTMLInputElement).value;
      const webhook = f.dataset.webhook!;
      const pdf = f.dataset.pdf!;

      try {
        await fetch(webhook, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
      } catch (_) {}

      const card = f.closest('[style*="border-radius:16px"]')!;
      const success = card.querySelector('.lead-success') as HTMLElement;
      const downloadLink = card.querySelector('.lead-download') as HTMLAnchorElement;
      f.style.display = 'none';
      success.style.display = 'block';
      downloadLink.href = pdf;
    });
  });
</script>
