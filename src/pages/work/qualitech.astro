---
import BaseLayout from '../../layouts/BaseLayout.astro';

const team = [
  {
    name: 'Antonio Cumberbatch',
    role: 'Technical Lead & Account Director',
    bio: 'Antonio led architecture, Azure infrastructure, and technical strategy for the engagement. He owns overall delivery and works directly with company leadership to align the product roadmap to business goals.',
  },
  {
    name: 'Hamza Syed',
    role: 'Automation & Portal Engineer',
    bio: 'Hamza built every automation workflow and is the primary developer on the QT Digital portal. He works across n8n, API development, and frontend delivery — often taking a module from design to deployed in a single sprint.',
  },
  {
    name: 'Rakib Hasan',
    role: 'UI/UX Designer',
    bio: 'Rakib designs every module before Hamza builds it. Every department dashboard, form, and interface in the QT Digital portal was designed by Rakib before a line of code was written.',
  },
];

const workstreams = [
  {
    name: 'Website Rebuild',
    status: 'DELIVERED',
    statusLabel: 'Delivered — April 2026',
    desc: 'Full WordPress rebuild across 30+ pages including 9 dedicated service sector pages. Mobile responsive, staff training delivered, fully handed over.',
    tags: ['WordPress', 'Divi 5'],
  },
  {
    name: 'Operations Automation',
    status: 'ACTIVE',
    statusLabel: 'Active',
    desc: 'Vendor PO intake from supplier emails, AI-drafted follow-up responses, escalation alerts when responses go overdue, and KPI summaries delivered to the ops manager. Runs continuously via n8n.',
    tags: ['n8n', 'Gmail API', 'OpenAI'],
  },
  {
    name: 'Sales Automation',
    status: 'ACTIVE',
    statusLabel: 'Active',
    desc: 'Weekly quotation follow-up sequences per salesperson, AI-personalised per contact, with response tracking. Replaced manual sales chase-up entirely.',
    tags: ['n8n', 'OpenAI', 'PostgreSQL'],
  },
  {
    name: 'Marketing Automation',
    status: 'ACTIVE',
    statusLabel: 'Active',
    desc: 'Biweekly outreach to Caribbean utility and electric companies, AI-tailored per region, with human handoff triggers when prospects respond.',
    tags: ['n8n', 'OpenAI', 'Gmail API'],
  },
  {
    name: 'Qiara AI Voice Calling',
    status: 'PHASE1',
    statusLabel: 'Phase 1 Complete',
    desc: 'Outbound AI voice calling agent that holds context-aware conversations on behalf of the company and hands off to a human when needed. SIP signaling, carrier integration, and AI agent activation complete. Call logging in production.',
    tags: ['Retell AI', 'Twilio', 'n8n'],
  },
  {
    name: 'QT Digital Portal',
    status: 'IN_DEV',
    statusLabel: 'In Development',
    desc: 'Centralised React portal replacing all isolated Google Sheets. Department dashboards for Operations, Sales, Marketing, Finance, and HR. The MD sees across all departments. Real-time notifications, email thread history per record, and workflow triggers all wired to a single database.',
    tags: ['React', 'NestJS', 'PostgreSQL on Azure'],
  },
  {
    name: 'HR Module',
    status: 'IN_DEV',
    statusLabel: 'In Development',
    desc: 'Leave request tracking and approval workflow for the HR department. Staff submit requests through the portal, managers review and approve, and notification flows keep both sides updated automatically. Replaces manual HR coordination across email and spreadsheets.',
    tags: ['React', 'n8n', 'PostgreSQL on Azure'],
  },
];

function badgeStyle(status: string): string {
  if (status === 'DELIVERED') return 'background:rgba(34,197,94,0.12);color:#4ade80;border:1px solid rgba(34,197,94,0.25);';
  if (status === 'ACTIVE')    return 'background:rgba(59,130,246,0.12);color:#60a5fa;border:1px solid rgba(59,130,246,0.25);';
  if (status === 'PHASE1')    return 'background:rgba(255,107,43,0.12);color:var(--color-accent);border:1px solid rgba(255,107,43,0.25);';
  return 'background:rgba(148,163,184,0.1);color:#94a3b8;border:1px solid rgba(148,163,184,0.2);';
}
---

<BaseLayout
  title="QT Digital — Qualitech Case Study"
  description="Replacing 7 isolated spreadsheets with a single source of truth. Automation, a centralised database, and a department portal — built and delivered by ARC."
>

  <!-- HERO BANNER -->
  <div class="reveal" style="position:relative;width:100%;height:500px;background:var(--color-surface-2);border-bottom:2px dashed var(--color-border);display:flex;align-items:center;justify-content:center;overflow:hidden;">
    <div style="position:absolute;inset:0;background:rgba(15,22,36,0.75);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:2rem;">
      <p style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-accent);margin:0 0 1rem;">AI &amp; Automation &middot; n8n &middot; Azure</p>
      <h1 style="font-family:var(--font-display);font-size:clamp(1.875rem,5vw,3.25rem);font-weight:800;color:#fff;margin:0 0 1rem;line-height:1.15;">QT Digital — Qualitech Machining Services</h1>
      <p style="font-size:1.125rem;color:rgba(255,255,255,0.75);margin:0 0 0.625rem;max-width:620px;">Replacing 7 isolated spreadsheets with a single source of truth.</p>
      <p style="font-size:0.9375rem;color:rgba(255,255,255,0.5);margin:0;font-style:italic;">Automation, a centralised database, and a department portal — built and delivered by ARC.</p>
    </div>
    <span style="position:absolute;bottom:0.875rem;right:1rem;font-size:0.6875rem;color:rgba(255,255,255,0.2);font-style:italic;">[Hero image — add as background-image when available]</span>
  </div>

  <!-- NAV + STATS -->
  <section style="padding:2.5rem 1.5rem 2rem;">
    <div style="max-width:900px;margin:0 auto;">
      <a href="/work" style="font-size:0.875rem;color:var(--color-text-muted);text-decoration:none;display:inline-flex;align-items:center;gap:0.375rem;margin-bottom:1.5rem;">&larr; All Work</a>
      <div class="reveal" style="background:rgba(255,107,43,0.06);border:1px solid rgba(255,107,43,0.18);border-radius:14px;padding:1.25rem 1.75rem;display:flex;align-items:center;gap:1.5rem;margin-bottom:1.75rem;">
        <div style="width:80px;height:80px;border-radius:12px;background:#fff;border:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;padding:8px;">
          <img src="/images/logos/qualitech-logo.png" alt="Qualitech logo" width="64" height="64" style="width:64px;height:64px;object-fit:contain;" />
        </div>
        <div>
          <p style="font-family:var(--font-display);font-size:1.25rem;font-weight:700;color:var(--color-text);margin:0 0 0.375rem;">Qualitech Machining Services</p>
          <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-accent);">AI &amp; Automation &middot; n8n &middot; Azure</span>
          <div style="margin-top:0.625rem;">
            <a href="https://quali.tech/" target="_blank" rel="noopener noreferrer" style="font-size:0.8125rem;font-weight:600;color:var(--color-accent);text-decoration:none;border:1px solid rgba(255,107,43,0.35);border-radius:6px;padding:0.25rem 0.75rem;display:inline-flex;align-items:center;gap:0.375rem;transition:background 0.15s;" onmouseover="this.style.background='rgba(255,107,43,0.1)'" onmouseout="this.style.background='transparent'">
              Visit Site <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>
      </div>
      <div class="reveal" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;">
        {[['9', 'Service Sectors'], ['5', 'Departments Automated'], ['Active', 'AI Voice Calling'], ['Embedded', 'Tech Department']].map(([val, label]) => (
          <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:1rem;text-align:center;">
            <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:800;color:var(--color-accent);">{val}</div>
            <div style="font-size:0.8125rem;color:var(--color-text-muted);margin-top:0.25rem;">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section style="padding:2rem 1.5rem 3rem;">
    <div style="max-width:900px;margin:0 auto;">
      <div class="reveal" style="margin-bottom:1.75rem;">
        <p style="font-size:0.8125rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);margin:0 0 0.375rem;">The Team</p>
        <h2 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;margin:0;">Three people. One engagement.</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem;">
        {team.map(person => (
          <div class="card-lift reveal" style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.75rem;display:flex;flex-direction:column;align-items:center;text-align:center;">
            <div style="width:80px;height:80px;border-radius:50%;background:var(--color-surface-2);border:2px dashed var(--color-border);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;flex-shrink:0;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            </div>
            <p style="font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--color-text);margin:0 0 0.25rem;">{person.name}</p>
            <p style="font-size:0.8125rem;font-weight:600;color:var(--color-accent);margin:0 0 0.875rem;">{person.role}</p>
            <p style="font-size:0.875rem;color:var(--color-text-muted);line-height:1.65;margin:0;">{person.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- THE CLIENT -->
  <section style="padding:0 1.5rem 3rem;">
    <div class="prose" style="max-width:900px;margin:0 auto;">
      <h2>The Client</h2>
      <p>Qualitech Machining Services Limited is a Trinidad-based industrial engineering and fabrication company serving the energy, manufacturing, and utilities sectors across the Caribbean. They operate across 9 service lines with a regional client base that includes utilities and industrial operators across the Caribbean.</p>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section style="padding:0 1.5rem 3rem;">
    <div class="prose" style="max-width:900px;margin:0 auto;">
      <h2>The Problem</h2>
      <p>Every department was running on its own isolated Google Sheet. Operations tracked purchase orders in one file. Sales tracked quotation follow-ups in another. Marketing ran outreach from a third. Finance and HR had their own. None of these talked to each other, none had audit history, and any automation built on top of them depended on staff remembering to update a cell.</p>
      <p>The company's MD had a clear vision: one database, one portal, every department with their own view, and leadership seeing across all of it. Our job was to build it.</p>
    </div>
  </section>

  <!-- WHAT WAS BUILT — WORKSTREAM CARDS -->
  <section style="padding:0 1.5rem 3rem;">
    <div style="max-width:900px;margin:0 auto;">
      <div class="reveal" style="margin-bottom:1.5rem;">
        <h2 style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;margin:0;">What Was Built</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:1rem;">
        {workstreams.map(w => (
          <div class="card-lift reveal" style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.5rem;display:flex;flex-direction:column;gap:0.75rem;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;">
              <h3 style="font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--color-text);margin:0;">{w.name}</h3>
              <span style={`font-size:0.6875rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;padding:0.1875rem 0.625rem;border-radius:100px;white-space:nowrap;${badgeStyle(w.status)}`}>{w.statusLabel}</span>
            </div>
            <p style="font-size:0.9rem;color:var(--color-text-muted);line-height:1.65;margin:0;flex:1;">{w.desc}</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.375rem;padding-top:0.25rem;border-top:1px solid var(--color-border);">
              {w.tags.map(tag => (
                <span style="font-family:var(--font-mono);font-size:0.75rem;background:var(--color-surface-2);color:var(--color-text-muted);padding:0.1875rem 0.5rem;border-radius:4px;">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE DECISION -->
  <section style="padding:0 1.5rem 3rem;">
    <div class="prose" style="max-width:900px;margin:0 auto;">
      <h2>Centralise first. Automate second.</h2>
      <p>The core architectural decision on this engagement was sequencing. Building automations on top of isolated spreadsheets meant every workflow was fragile &mdash; one missing cell update could break a chain. We built the automation layer first to prove the logic, then migrated everything onto a single Azure PostgreSQL database.</p>
      <p>Once the migration is complete, the automations no longer depend on human data entry. They read from and write to the same source of truth the portal reads from. The portal was always the end goal; the automation layer was the proof of concept that got us there.</p>
      <p>n8n handles all automation logic and writes directly to the database via its native Postgres node. NestJS sits as a thin API layer handling only authentication, dashboard reads, and real-time notifications. No automation logic lives in the API layer &mdash; this keeps the system debuggable and the two concerns cleanly separated.</p>
    </div>
  </section>

  <!-- WHY CARIBBEAN BUSINESSES SHOULD CARE -->
  <section style="padding:0 1.5rem 4rem;">
    <div class="prose" style="max-width:900px;margin:0 auto;">
      <h2>Why Caribbean Businesses Should Care</h2>
      <p>Most growing businesses across the Caribbean reach the same inflection point. The spreadsheets that worked at 5 staff do not work at 25. Every department is running its own file. Nothing connects, nothing audits, and automation is not possible because there is no shared source of truth to build on top of.</p>
      <p>The approach here &mdash; centralise data first, automate second, then build the portal that gives leadership visibility across all of it &mdash; is directly applicable to any Caribbean company operating across multiple business functions. It does not require expensive enterprise software or a dedicated internal IT team. It requires a clear architecture, the right tooling, and a team that can build and embed alongside your operation.</p>
      <p>ARC builds embedded technical teams for Caribbean businesses at this stage. If your organisation is growing past informal tooling and you are ready to consolidate, Antonio is the right person to start that conversation with.</p>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--color-surface);border-top:1px solid var(--color-border);padding:4rem 1.5rem;">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <h2 style="font-family:var(--font-display);font-size:1.875rem;font-weight:800;margin-bottom:0.875rem;">Want to see what this looks like for your operation?</h2>
      <p style="color:var(--color-text-muted);margin-bottom:1.75rem;max-width:480px;margin-left:auto;margin-right:auto;">ARC builds embedded technical teams for growing businesses in the Caribbean and beyond.</p>
      <a href="/contact" style="background:var(--color-accent);color:#fff;padding:0.8125rem 1.75rem;border-radius:8px;font-weight:600;text-decoration:none;font-size:0.9375rem;display:inline-block;transition:background 0.2s;" onmouseover="this.style.background='var(--color-accent-hover)'" onmouseout="this.style.background='var(--color-accent)'">
        Get in Touch
      </a>
    </div>
  </section>

</BaseLayout>
