---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import nicoleImg from '../../assets/images/nicole-cumberbatch-sassi.jpg';
import clientPortalImg from '../../assets/images/sassi-client-portal.png';
import adminPortalImg from '../../assets/images/sassi-admin-portal.png';
import teamPhotoImg from '../../assets/images/sassi-team-photo.jpg';
---

<BaseLayout
  title="SASSI Logistics Platform — Case Study"
  description="How ARC Cloud Consulting built a full-stack logistics platform serving 200+ active users, replacing WhatsApp and spreadsheets with automated workflows."
>

  <section style="padding:4rem 1.5rem 2rem;">
    <div style="max-width:900px;margin:0 auto;">
      <a href="/work" style="font-size:0.875rem;color:var(--color-text-muted);text-decoration:none;display:inline-flex;align-items:center;gap:0.375rem;margin-bottom:1.5rem;">&larr; All Work</a>
      <div class="reveal" style="background:rgba(255,107,43,0.06);border:1px solid rgba(255,107,43,0.18);border-radius:14px;padding:1.25rem 1.75rem;display:flex;align-items:center;gap:1.5rem;margin-bottom:1.75rem;">
        <div style="width:80px;height:80px;border-radius:12px;background:#fff;border:1px solid rgba(0,0,0,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;padding:8px;">
          <img src="/images/logos/sassi-logo.svg" alt="SASSI logo" width="64" height="64" style="width:64px;height:64px;object-fit:contain;" />
        </div>
        <div>
          <p style="font-family:var(--font-display);font-size:1.25rem;font-weight:700;color:var(--color-text);margin:0 0 0.375rem;">SASSI Logistics</p>
          <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-accent);">Logistics &amp; Supply Chain &middot; Azure &middot; Full-Stack</span>
          <div style="margin-top:0.625rem;">
            <a href="https://sassi4trinis.com/" target="_blank" rel="noopener noreferrer" style="font-size:0.8125rem;font-weight:600;color:var(--color-accent);text-decoration:none;border:1px solid rgba(255,107,43,0.35);border-radius:6px;padding:0.25rem 0.75rem;display:inline-flex;align-items:center;gap:0.375rem;transition:background 0.15s;" onmouseover="this.style.background='rgba(255,107,43,0.1)'" onmouseout="this.style.background='transparent'">
              Visit Site <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>
      </div>
      <h1 class="reveal" style="font-family:var(--font-display);font-size:clamp(2rem,5vw,3.25rem);font-weight:800;line-height:1.2;margin-bottom:1.5rem;">SASSI Logistics Platform</h1>
      <div class="reveal" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;">
        {[['200+', 'Active Users'], ['AI-Powered', 'Support System'], ['Full SaaS', 'Managed by ARC']].map(([val, label]) => (
          <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:1rem;text-align:center;">
            <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:800;color:var(--color-accent);">{val}</div>
            <div style="font-size:0.8125rem;color:var(--color-text-muted);margin-top:0.25rem;">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="padding:2rem 1.5rem 5rem;">
    <div class="prose" style="max-width:900px;margin:0 auto;">

      <!-- ABOUT THE CLIENT -->
      <h2>About the Client</h2>
      <div style="display:flex;align-items:flex-start;gap:1.5rem;margin-bottom:1.5rem;flex-wrap:wrap;">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;flex-shrink:0;">
          <Image src={nicoleImg} width={96} height={96} alt="Nicole Cumberbatch — Founder, SASSI" style="width:96px;height:96px;border-radius:50%;object-fit:cover;object-position:center top;border:2px solid var(--color-border);" />
          <span style="font-size:0.6875rem;color:var(--color-text-muted);text-align:center;max-width:110px;line-height:1.4;">Nicole Cumberbatch<br/>Founder, SASSI</span>
        </div>
      </div>

      <h2>The Problem</h2>
      <p>Caribbean package forwarding businesses are growing. The model &mdash; give customers a US warehouse address, receive packages, and ship them home &mdash; is simple and scalable in theory. In practice, most operations at this stage run on WhatsApp groups, spreadsheets, and phone calls. Notifying 50 customers about their shipments takes the same effort as notifying 5. There is no audit trail, no client portal, and every workflow is a manual one.</p>
      <p>SASSI came to ARC with this exact problem and a clear goal: replace the informal stack with a real platform.</p>

      <h2>What Was Built</h2>
      <p>A full-stack logistics web application built entirely by ARC Cloud Consulting. Currently serving 200+ active users in production.</p>

      <h3>Core Modules</h3>
      <ul>
        <li><strong>Client portal:</strong> pre-alerts, invoice management, wallet and payment tracking</li>
        <li><strong>Admin portal:</strong> warehouse receiving, pre-alert management, invoicing, reporting</li>
        <li><strong>SNS (Shop &amp; Ship):</strong> purchase-on-behalf service for US vendor purchases</li>
        <li><strong>Warehouse Receipt module:</strong> currently in active development</li>
        <li><strong>AI-powered support chatbot:</strong> handles support requests, creates and assigns Trello tickets, checks for duplicates, notifies the dev team via Slack</li>
      </ul>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:0.875rem;margin:1.75rem 0 0.5rem;">
        <div>
          <Image src={clientPortalImg} width={560} height={350} alt="SASSI Client Portal — Pre-alerts and Invoice View" style="width:100%;height:auto;border-radius:8px;border:1px solid var(--color-border);" />
          <p style="font-size:0.75rem;color:var(--color-text-muted);text-align:center;margin:0.5rem 0 0;">Client Portal</p>
        </div>
        <div>
          <Image src={adminPortalImg} width={560} height={350} alt="SASSI Admin Portal — Warehouse Receiving Dashboard" style="width:100%;height:auto;border-radius:8px;border:1px solid var(--color-border);" />
          <p style="font-size:0.75rem;color:var(--color-text-muted);text-align:center;margin:0.5rem 0 0;">Admin Portal</p>
        </div>
      </div>

      <h2>Stack</h2>
      <p>Azure (full infrastructure), full-stack web application, n8n automation, GPT-4 (support chatbot), Trello API, Slack integration, PostgreSQL.</p>

      <h2>The AI Support System</h2>
      <p>Before: a client messages on WhatsApp with a support issue. Antonio sees it (eventually), creates a Trello ticket manually, assigns it.</p>
      <p>After: a client messages in the support chat. An n8n workflow intercepts the message, checks for duplicate tickets based on client ID and issue type, creates a Trello ticket if none exists, assigns it to the right team member, notifies the dev team on Slack, and replies to the client with a ticket reference number.</p>
      <p>Antonio's direct involvement in routine support requests dropped from every single one to only those that need a human decision.</p>

      <h2>Outcomes</h2>
      <ul>
        <li>200+ active users in production</li>
        <li>WhatsApp mass notifications replaced by automated client alerts</li>
        <li>Support tickets created, assigned, and tracked without Antonio's direct involvement</li>
        <li>Operating as a fully managed SaaS product under ARC Cloud Consulting</li>
      </ul>

      <h2>Sound familiar?</h2>
      <p>Package forwarding is one of the fastest-growing informal sectors in the Caribbean. Most of these businesses are still running on WhatsApp and spreadsheets, not because the owners aren't serious about growth, but because no one has built the tooling for them.</p>
      <p>SASSI proves that a proper platform for this model is achievable and affordable at Caribbean scale. Everything built here was designed specifically for how forwarding businesses actually operate in the region. Not adapted from a US SaaS. Built from scratch for the problem.</p>
      <p>If you're running a forwarding or logistics operation and still managing customers through a group chat, reach out. We've done this before.</p>

      <div style="margin-top:2rem;">
        <Image src={teamPhotoImg} width={900} height={500} alt="SASSI team" style="width:100%;height:auto;border-radius:10px;border:1px solid var(--color-border);object-fit:cover;" />
      </div>

    </div>
  </section>

  <!-- DESIGN CONTRIBUTOR -->
  <section style="padding:0 1.5rem 3rem;">
    <div style="max-width:900px;margin:0 auto;">
      <p class="reveal" style="font-size:0.8125rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);margin:0 0 0.375rem;">Design</p>
      <h2 class="reveal" style="font-family:var(--font-display);font-size:1.625rem;font-weight:800;margin:0 0 1.25rem;">UI/UX</h2>
      <div class="card-lift reveal" style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;padding:1.75rem;display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">
        <img src="/images/Rakib%20Hasan.jpeg" alt="Rakib Hasan" width="80" height="80" style="width:80px;height:80px;border-radius:50%;object-fit:cover;object-position:center top;border:2px solid var(--color-border);flex-shrink:0;" />
        <div style="flex:1;min-width:240px;">
          <p style="font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--color-text);margin:0 0 0.25rem;">Rakib Hasan</p>
          <p style="font-size:0.8125rem;font-weight:600;color:var(--color-accent);margin:0 0 1rem;">UI/UX Designer &amp; Frontend Developer</p>
          <p style="font-size:0.9375rem;color:var(--color-text-muted);line-height:1.7;margin:0;font-style:italic;">&ldquo;Working on SASSI allowed me to dive deep into information architecture and data clarity. I led the design of the user portal, focusing heavily on simplifying shipment tracking and pre-alert systems. By balancing a clean aesthetic with powerful functionality, we built a platform that makes managing complex global logistics feel effortless.&rdquo;</p>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--color-surface);border-top:1px solid var(--color-border);padding:4rem 1.5rem;">
    <div style="max-width:900px;margin:0 auto;text-align:center;">
      <h2 style="font-family:var(--font-display);font-size:1.875rem;font-weight:800;margin-bottom:1rem;">Running a logistics business on informal tools?</h2>
      <p style="color:var(--color-text-muted);margin-bottom:1.75rem;max-width:520px;margin-left:auto;margin-right:auto;">ARC builds purpose-built platforms for Caribbean logistics and forwarding operations. Let Antonio walk you through what this looks like.</p>
      <a href="/contact" style="background:var(--color-accent);color:#fff;padding:0.8125rem 1.75rem;border-radius:8px;font-weight:600;text-decoration:none;font-size:0.9375rem;display:inline-block;transition:background 0.2s;" onmouseover="this.style.background='var(--color-accent-hover)'" onmouseout="this.style.background='var(--color-accent)'">
        Start the Conversation
      </a>
    </div>
  </section>

</BaseLayout>
