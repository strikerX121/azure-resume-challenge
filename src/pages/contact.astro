---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Antonio Cumberbatch"
  description="Book a discovery call, send a project brief, or just say hello. Based in Trinidad, working remotely across the Caribbean and beyond."
>

  <section class="contact-hero">
    <div class="container">
      <p class="reveal eyebrow">Contact</p>
      <h1 class="reveal">Let&apos;s Build Something.</h1>
      <p class="reveal subheading">I reply within 48 hours on business days.</p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container contact-grid">

      <!-- Contact Form -->
      <div class="reveal">
        <h2 class="section-heading">Send a Message</h2>
        <form id="contact-form" class="contact-form">
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name" />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com" />
          </div>
          <div class="field">
            <label for="subject">Subject</label>
            <select id="subject" name="subject">
              <option value="General Enquiry">General Enquiry</option>
              <option value="Project Scope">Project Scope</option>
              <option value="Discovery Call">Discovery Call</option>
              <option value="Workshop">Workshop</option>
            </select>
          </div>
          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" required rows="5" placeholder="Tell me about your project or question..."></textarea>
          </div>
          <button type="submit" class="btn-primary">Send Message</button>
          <p id="form-status" class="form-status"></p>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="reveal contact-sidebar">

        <!-- Book a Call card -->
        <div class="card" style="margin-bottom:1.75rem;">
          <h2 class="section-heading" style="margin-bottom:1rem;">Book a Call Directly</h2>
          <div class="booking-icon">
            <svg width="22" height="22" fill="none" stroke="var(--color-accent)" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <p class="booking-title">30-Minute Discovery Call</p>
          <p class="booking-desc">We&apos;ll map out your project, align on scope, and figure out the best way to move forward. No pitch, just a real conversation.</p>
          <ul class="booking-list">
            <li>
              <svg width="13" height="13" fill="none" stroke="var(--color-accent)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Cloud architecture &amp; Azure infrastructure
            </li>
            <li>
              <svg width="13" height="13" fill="none" stroke="var(--color-accent)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Custom software &amp; product development
            </li>
            <li>
              <svg width="13" height="13" fill="none" stroke="var(--color-accent)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Microsoft 365 &amp; AI automation
            </li>
            <li>
              <svg width="13" height="13" fill="none" stroke="var(--color-accent)" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              IT strategy for Caribbean businesses
            </li>
          </ul>
          <a href="https://calendar.app.google/hxSqa4yRVmLW5fubA" target="_blank" rel="noopener noreferrer" class="btn-primary btn-block">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Book a Time
          </a>
        </div>

        <!-- Contact links card -->
        <div class="card">
          <h3 class="card-heading">Other Ways to Reach Me</h3>
          <div class="contact-links">

            <a href="mailto:antonio.cumberbatch@arccloudconsulting.com" class="contact-link">
              <span class="contact-icon">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <span class="contact-link-text">
                <strong>Email</strong>
                antonio.cumberbatch@arccloudconsulting.com
              </span>
            </a>

            <a href="https://api.whatsapp.com/send/?phone=18683237810" target="_blank" rel="noopener noreferrer" class="contact-link">
              <span class="contact-icon">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </span>
              <span class="contact-link-text">
                <strong>WhatsApp</strong>
                +1 (868) 323-7810
              </span>
            </a>

            <a href="https://www.linkedin.com/in/antonio-c-484433137/" target="_blank" rel="noopener noreferrer" class="contact-link">
              <span class="contact-icon">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </span>
              <span class="contact-link-text">
                <strong>LinkedIn</strong>
                Antonio Cumberbatch
              </span>
            </a>

            <a href="https://www.instagram.com/arc.cloudconsulting/" target="_blank" rel="noopener noreferrer" class="contact-link">
              <span class="contact-icon">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </span>
              <span class="contact-link-text">
                <strong>Instagram</strong>
                @arc.cloudconsulting
              </span>
            </a>

          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-hero {
    padding: 4rem 1.5rem 3rem;
  }

  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
  }

  .contact-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin: 0 0 1rem;
  }

  .subheading {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 480px;
    margin: 0;
  }

  .contact-body {
    padding: 0 1.5rem 5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .field input,
  .field select,
  .field textarea {
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--color-accent);
  }

  .field textarea {
    resize: vertical;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--color-accent);
    color: #fff;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9375rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
    font-family: var(--font-body);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
  }

  .btn-block {
    width: 100%;
  }

  .form-status {
    font-size: 0.875rem;
    color: var(--color-accent);
    display: none;
    margin: 0;
  }

  /* Sidebar */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .booking-icon {
    width: 48px;
    height: 48px;
    background: rgba(255, 107, 43, 0.12);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .booking-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .booking-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .booking-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .booking-list li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .booking-list svg {
    flex-shrink: 0;
  }

  .card-heading {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 1.25rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    text-decoration: none;
    color: var(--color-text-muted);
    padding: 0.625rem 0.5rem;
    border-radius: 8px;
    transition: background 0.15s;
  }

  .contact-link:hover {
    background: var(--color-surface-2);
  }

  .contact-icon {
    width: 36px;
    height: 36px;
    background: var(--color-surface-2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .contact-link-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
    overflow: hidden;
  }

  .contact-link-text strong {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .contact-link-text span,
  .contact-link-text {
    font-size: 0.8125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-sidebar {
      order: -1;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name    = (form.elements.namedItem('name')    as HTMLInputElement).value;
    const email   = (form.elements.namedItem('email')   as HTMLInputElement).value;
    const subject = (form.elements.namedItem('subject') as HTMLSelectElement).value;
    const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value;

    const body = `Name: ${name}\nEmail: ${email}\n\n${message}`;
    window.location.href = `mailto:antonio.cumberbatch@arccloudconsulting.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>
