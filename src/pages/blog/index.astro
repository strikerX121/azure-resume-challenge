---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const remainingPosts = posts.slice(1);

function readTime(body: string) {
  return Math.ceil(body.split(/\s+/).length / 200);
}

const categories = ['All', ...new Set(posts.map(p => p.data.category))];
---

<BaseLayout
  title="Blog — Antonio Cumberbatch"
  description="Cloud architecture, AI automation, building in public, and consulting from the Caribbean. Real projects, real numbers."
>

  <!-- HERO -->
  <section style="padding:5rem 1.5rem 4rem;position:relative;overflow:hidden;">
    <!-- subtle background grid -->
    <div aria-hidden="true" style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,107,43,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,107,43,0.04) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;"></div>
    <!-- gradient fade at bottom -->
    <div aria-hidden="true" style="position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(transparent,var(--color-bg));pointer-events:none;"></div>

    <div style="max-width:1200px;margin:0 auto;position:relative;z-index:1;">
      <p class="reveal" style="font-size:0.8125rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);margin-bottom:0.75rem;">Writing</p>
      <h1 class="reveal" style="font-family:var(--font-display);font-size:clamp(2.25rem,5.5vw,3.5rem);font-weight:800;line-height:1.15;margin-bottom:1.25rem;max-width:720px;">Cloud. AI. Caribbean.<br/>Building in Public.</h1>
      <p class="reveal" style="font-size:1.0625rem;color:var(--color-text-muted);max-width:540px;margin-bottom:1.75rem;line-height:1.7;">Real projects, real decisions, real numbers from the field. Cloud architecture, AI adoption, and building a tech company from the Caribbean.</p>
      <a href="/rss.xml" class="reveal" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.5rem 1rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:100px;font-size:0.8125rem;font-weight:600;color:var(--color-text-muted);text-decoration:none;transition:border-color 0.2s,color 0.2s;" onmouseover="this.style.borderColor='var(--color-accent)';this.style.color='var(--color-accent)'" onmouseout="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-muted)'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 010 4.36 2.18 2.18 0 010-4.36M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/></svg>
        RSS Feed
      </a>
    </div>
  </section>

  <!-- CATEGORY FILTER -->
  <section style="padding:0 1.5rem 2.5rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <div id="category-filters" style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {categories.map((cat, i) => (
          <button
            class="cat-btn"
            data-category={cat}
            style={`padding:0.4375rem 1rem;border-radius:100px;font-size:0.8125rem;font-weight:600;border:1px solid;cursor:pointer;transition:all 0.15s;${i === 0 ? 'background:var(--color-accent);color:#fff;border-color:var(--color-accent);' : 'background:transparent;color:var(--color-text-muted);border-color:var(--color-border);'}`}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED POST -->
  {featuredPost && (
    <section style="padding:0 1.5rem 3rem;">
      <div style="max-width:1200px;margin:0 auto;">
        <a
          href={`/blog/${featuredPost.slug}`}
          class="reveal featured-post"
          data-category={featuredPost.data.category}
          style="display:grid;grid-template-columns:1fr 1fr;gap:0;background:var(--color-surface);border:1px solid var(--color-border);border-radius:16px;overflow:hidden;text-decoration:none;transition:border-color 0.2s,transform 0.2s,box-shadow 0.2s;"
          onmouseover="this.style.borderColor='var(--color-accent)';this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 40px rgba(0,0,0,0.4)'"
          onmouseout="this.style.borderColor='var(--color-border)';this.style.transform='translateY(0)';this.style.boxShadow='none'"
        >
          <!-- image -->
          <div style="overflow:hidden;aspect-ratio:16/9;background:var(--color-surface-2);" class="featured-img-wrap">
            {featuredPost.data.image ? (
              <img
                src={featuredPost.data.image}
                alt={featuredPost.data.title}
                style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s;"
                class="featured-img"
              />
            ) : (
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1a1a2e,#16213e);">
                <span style="font-family:var(--font-display);font-size:2rem;font-weight:800;color:var(--color-accent);opacity:0.4;">AC</span>
              </div>
            )}
          </div>
          <!-- text -->
          <div style="padding:2.5rem;display:flex;flex-direction:column;justify-content:center;">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;flex-wrap:wrap;">
              <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-accent);background:rgba(255,107,43,0.1);border:1px solid rgba(255,107,43,0.25);padding:0.2rem 0.625rem;border-radius:100px;">{featuredPost.data.category}</span>
              <span style="font-size:0.75rem;color:var(--color-text-muted);">Featured &middot; {readTime(featuredPost.body)} min read</span>
            </div>
            <h2 style="font-family:var(--font-display);font-size:clamp(1.25rem,2.5vw,1.75rem);font-weight:800;color:var(--color-text);margin:0 0 1rem;line-height:1.3;">{featuredPost.data.title}</h2>
            <p style="font-size:0.9375rem;color:var(--color-text-muted);line-height:1.7;margin:0 0 1.5rem;flex:1;">{featuredPost.data.description}</p>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <time style="font-size:0.8125rem;color:var(--color-text-muted);">
                {new Date(featuredPost.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <span style="font-size:0.875rem;font-weight:600;color:var(--color-accent);">Read &rarr;</span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- POST GRID -->
  <section style="padding:0 1.5rem 6rem;">
    <div style="max-width:1200px;margin:0 auto;">
      {remainingPosts.length > 0 && (
        <div id="post-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.5rem;">
          {remainingPosts.map(post => (
            <a
              href={`/blog/${post.slug}`}
              class="card-lift reveal post-card"
              data-category={post.data.category}
              style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:12px;overflow:hidden;text-decoration:none;display:flex;flex-direction:column;"
            >
              <!-- image -->
              <div style="overflow:hidden;aspect-ratio:16/9;background:var(--color-surface-2);">
                {post.data.image ? (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    style="width:100%;height:100%;object-fit:cover;transition:transform 0.35s;"
                    class="card-img"
                  />
                ) : (
                  <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1a1a2e,#16213e);">
                    <span style="font-family:var(--font-display);font-size:1.5rem;font-weight:800;color:var(--color-accent);opacity:0.4;">AC</span>
                  </div>
                )}
              </div>
              <!-- content -->
              <div style="padding:1.5rem;display:flex;flex-direction:column;flex:1;">
                <div style="margin-bottom:0.875rem;">
                  <span style="font-size:0.6875rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent);background:rgba(255,107,43,0.1);border:1px solid rgba(255,107,43,0.22);padding:0.2rem 0.5rem;border-radius:100px;">{post.data.category}</span>
                </div>
                <h2 style="font-family:var(--font-display);font-size:1.0625rem;font-weight:700;color:var(--color-text);margin:0 0 0.625rem;line-height:1.4;">{post.data.title}</h2>
                <p style="font-size:0.875rem;color:var(--color-text-muted);line-height:1.6;flex:1;margin:0 0 1.25rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{post.data.description}</p>
                <div style="display:flex;align-items:center;justify-content:space-between;padding-top:0.875rem;border-top:1px solid var(--color-border);">
                  <div style="display:flex;align-items:center;gap:0.625rem;">
                    <span style="font-size:0.75rem;color:var(--color-text-muted);">{readTime(post.body)} min read</span>
                    <span style="color:var(--color-border);">&middot;</span>
                    <time style="font-size:0.75rem;color:var(--color-text-muted);">
                      {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </div>
                  <span style="font-size:0.8125rem;font-weight:600;color:var(--color-accent);">Read &rarr;</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      {posts.length === 0 && (
        <p style="color:var(--color-text-muted);text-align:center;padding:4rem 0;">No posts yet — check back soon.</p>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  @media (max-width: 768px) {
    .featured-post { grid-template-columns: 1fr !important; }
    .featured-img-wrap { aspect-ratio: 16/9; }
  }
  .featured-post:hover .featured-img { transform: scale(1.04); }
  a:hover .card-img { transform: scale(1.05); }
  .post-card[style*="display:none"] { display: none !important; }
</style>

<script>
  const btns = document.querySelectorAll('.cat-btn');
  const cards = document.querySelectorAll('.post-card');
  const featured = document.querySelector('.featured-post') as HTMLElement | null;

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.category || 'All';

      // update button styles
      btns.forEach(b => {
        const el = b as HTMLElement;
        el.style.background = 'transparent';
        el.style.color = 'var(--color-text-muted)';
        el.style.borderColor = 'var(--color-border)';
      });
      const active = btn as HTMLElement;
      active.style.background = 'var(--color-accent)';
      active.style.color = '#fff';
      active.style.borderColor = 'var(--color-accent)';

      // filter grid cards
      cards.forEach(card => {
        const el = card as HTMLElement;
        const cardCat = el.dataset.category || '';
        el.style.display = (cat === 'All' || cardCat === cat) ? '' : 'none';
      });

      // show/hide featured post
      if (featured) {
        const featCat = featured.dataset.category || '';
        featured.style.display = (cat === 'All' || featCat === cat) ? '' : 'none';
      }
    });
  });
</script>
