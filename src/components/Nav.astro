---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/services', label: 'Services' },
  { href: '/resume', label: 'Resume' },
  { href: '/blog', label: 'Blog' },
  { href: '/shop', label: 'Shop' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header style="position:fixed;top:0;left:0;right:0;z-index:50;background:var(--color-navy);box-shadow:0 1px 0 rgba(255,255,255,0.06);">
  <nav style="max-width:1200px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:60px;">

    <!-- Logo -->
    <a href="/" style="display:flex;align-items:center;gap:0.625rem;text-decoration:none;">
      <span style="width:32px;height:32px;background:var(--color-accent);border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:800;font-size:0.8125rem;color:#fff;letter-spacing:-0.5px;">AC</span>
      <span style="font-family:var(--font-display);font-weight:600;font-size:0.9375rem;color:#fff;">Antonio Cumberbatch</span>
    </a>

    <!-- Desktop links -->
    <div class="desktop-nav" style="display:flex;align-items:center;gap:0.25rem;">
      {navLinks.map(link => (
        <a
          href={link.href}
          style={`font-size:0.8125rem;font-weight:500;text-decoration:none;letter-spacing:0.05em;text-transform:uppercase;padding:0.375rem 0.875rem;border-radius:5px;transition:color 0.2s,background 0.2s;color:${currentPath.startsWith(link.href) ? '#fff' : 'rgba(255,255,255,0.65)'};background:${currentPath.startsWith(link.href) ? 'rgba(255,255,255,0.08)' : 'transparent'}`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Hamburger (mobile) -->
    <button id="nav-toggle" aria-label="Open menu" style="display:none;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:6px;cursor:pointer;padding:0.4375rem 0.625rem;">
      <svg width="20" height="20" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;flex-direction:column;padding:0.75rem 1.5rem 1.25rem;gap:0.25rem;border-top:1px solid rgba(255,255,255,0.08);">
    {navLinks.map(link => (
      <a
        href={link.href}
        style={`font-size:0.875rem;font-weight:500;text-decoration:none;padding:0.5rem 0.625rem;border-radius:5px;color:${currentPath.startsWith(link.href) ? '#fff' : 'rgba(255,255,255,0.65)'}`}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<!-- Spacer to prevent content from hiding under fixed nav -->
<div style="height:64px;"></div>

<style>
  @media (max-width: 768px) {
    .desktop-nav { display: none !important; }
    #nav-toggle { display: block !important; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu!.style.display = menu!.style.display === 'flex' ? 'none' : 'flex';
  });
</script>

