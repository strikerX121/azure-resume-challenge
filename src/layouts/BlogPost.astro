---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
  image?: string;
}

const { title, description, pubDate, category, tags, image } = Astro.props;

function readTime(body: string) {
  const words = body.split(/\s+/).length;
  return Math.ceil(words / 200);
}
---

<BaseLayout
  title={`${title} — Antonio Cumberbatch`}
  description={description}
  ogImage={image}
  ogType="article"
  isBlogPost={true}
  pubDate={pubDate.toISOString()}
>

  <article>
    <!-- Post hero image -->
    {image && (
      <div style="width:100%;max-height:420px;overflow:hidden;background:var(--color-surface-2);">
        <img src={image} alt={title} style="width:100%;height:420px;object-fit:cover;display:block;" />
      </div>
    )}
    <!-- Post header -->
    <header style="padding:3rem 1.5rem 2rem;max-width:860px;margin:0 auto;">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;flex-wrap:wrap;">
        <span style="font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--color-accent);">{category}</span>
        <span style="color:var(--color-border);">&middot;</span>
        <time style="font-size:0.875rem;color:var(--color-text-muted);">
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>

      <h1 style="font-family:var(--font-display);font-size:clamp(1.875rem,4vw,2.75rem);font-weight:800;line-height:1.2;margin-bottom:1.25rem;">{title}</h1>
      <p style="font-size:1.125rem;color:var(--color-text-muted);line-height:1.6;margin-bottom:1.5rem;">{description}</p>

      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {tags.map(tag => (
          <span style="font-family:var(--font-mono);font-size:0.75rem;background:var(--color-surface);border:1px solid var(--color-border);color:var(--color-text-muted);padding:0.25rem 0.625rem;border-radius:4px;">#{tag}</span>
        ))}
      </div>
    </header>

    <!-- Post body -->
    <div class="prose" style="padding:0 1.5rem 4rem;max-width:860px;margin:0 auto;">
      <slot />
    </div>

    <!-- Post footer -->
    <footer style="border-top:1px solid var(--color-border);padding:2.5rem 1.5rem;max-width:860px;margin:0 auto;">
      <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1.5rem;">

        <div style="display:flex;align-items:center;gap:0.875rem;">
          <img src="/images/me.png" alt="Antonio Cumberbatch" width="48" height="48" style="width:48px;height:48px;border-radius:50%;object-fit:cover;object-position:center top;border:2px solid rgba(255,107,43,0.3);flex-shrink:0;" />
          <div>
            <p style="font-size:0.875rem;color:var(--color-text-muted);margin:0 0 0.2rem;">Written by</p>
            <p style="font-weight:600;color:var(--color-text);margin:0;">Antonio Cumberbatch</p>
            <p style="font-size:0.875rem;color:var(--color-text-muted);margin:0;">Cloud Architect &amp; Consultant</p>
          </div>
        </div>

        <!-- follow.it subscription form -->
        <div style="flex:1;min-width:260px;max-width:380px;">
          <style>
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .form-preview {
              background-color: rgba(255,255,255,0.04) !important;
              border-style: solid !important;
              border-width: 1px !important;
              border-color: rgba(255,255,255,0.1) !important;
              box-shadow: none !important;
              margin-top: 0 !important;
              padding: 1.25rem 1.25rem !important;
              border-radius: 8px !important;
            }
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .form-preview .preview-heading h5 {
              color: #fff !important;
              font-family: "Inter", sans-serif !important;
              font-size: 0.9375rem !important;
              font-weight: 600 !important;
              text-align: left !important;
            }
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .form-preview .preview-input-field input {
              background-color: rgba(255,255,255,0.06) !important;
              border: 1px solid rgba(255,255,255,0.15) !important;
              color: #fff !important;
              font-family: "Inter", sans-serif !important;
              text-align: left !important;
              padding: 0 0.75rem !important;
              border-radius: 6px !important;
            }
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .form-preview .preview-input-field input::placeholder,
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .form-preview .preview-input-field input:-ms-input-placeholder,
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .form-preview .preview-input-field input::-ms-input-placeholder {
              color: rgba(255,255,255,0.4) !important;
            }
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .form-preview .preview-submit-button button {
              background-color: #FF6B2B !important;
              color: #fff !important;
              font-family: "Inter", sans-serif !important;
              font-weight: 600 !important;
              font-size: 0.9375rem !important;
              border-radius: 6px !important;
            }
            .arc-followit .followit--follow-form-container[attr-a][attr-b][attr-c][attr-d][attr-e][attr-f] .powered-by-line {
              color: rgba(255,255,255,0.3) !important;
              font-family: "Inter", sans-serif !important;
              font-size: 0.75rem !important;
              justify-content: flex-start !important;
            }
          </style>
          <div class="arc-followit">
            <div class="followit--follow-form-container" attr-a attr-b attr-c attr-d attr-e attr-f>
              <form action="https://api.follow.it/subscription-form/ODV6eXovbUxrM0pVemdEMWdkaTlCTDZOREx0aEtPTUR6aEZCMCtJYW8xQUc1aXF5SkxJaWFCVStYL3R2TWt3VXQxVUFJYVRUN1pENHNpWTUrbThqWUpmYVpzR01DNEN1SWtDVVc4WDFZcjJpQnpLVkp3TEljcHg1WjFPaWhpSit8eFIrWjdmbnZQYlNrL1FEWklIOWZUbzQwWWpwbnQ3STdCV0taa2ZPV0NYVT0=/8" method="post">
                <div class="form-preview">
                  <div class="preview-heading"><h5>Get new posts by email</h5></div>
                  <div class="preview-input-field"><input type="email" name="email" required placeholder="Enter your email" spellcheck="false" /></div>
                  <div class="preview-submit-button"><button type="submit">Subscribe</button></div>
                </div>
              </form>
              <a href="https://follow.it" class="powered-by-line" target="_blank" rel="noopener">Powered by <img src="https://follow.it/images/colored-logo.svg" alt="follow.it" height="14px" style="margin-left:6px;opacity:0.6;" /></a>
            </div>
          </div>
        </div>
      </div>

      <div style="margin-top:2rem;padding-top:2rem;border-top:1px solid var(--color-border);">
        <a href="/blog" style="font-size:0.9375rem;font-weight:600;color:var(--color-accent);text-decoration:none;">&larr; Back to all posts</a>
      </div>
    </footer>
  </article>

</BaseLayout>

